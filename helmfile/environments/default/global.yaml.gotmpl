---
global:
  domain: "kubernetes.local"
  # global.matrixDomain is the public-facing domain of the synapse server. See the documentation linked below for implications of setting this value.
  # If `global.matrixDomain` is not set, it will be `<global.hostname.synapse>.<global.domain>`.
  # Note that this value can only be set once at setup.
  # ref: https://element-hq.github.io/synapse/latest/delegate.html
  matrixDomain: ""

  # resourcePreset sets the default resources for all applications
  # allowed values "none","nano" "micro" "small" "medium" "large" "xlarge" "2xlarge"
  resourcesPreset: "small"

  # per-app resource presets override the global default above
  # if not set, the app falls back to global.resourcesPreset
  resourcesPresetPerApp:
    collabora: "small"
    elementweb: "nano"
    keycloak: "small"
    ollama: "small"
    synapse: "large"
    grist: "small"
    livekit: "medium"
    meet:
      backend: "micro"
      frontend: "nano"
    nextcloud: "medium"
    docs:
      backend: "micro"
      frontend: "nano"
      celery: "micro"
      yProvider: "micro"
      docspec: "micro"
    drive:
      backend: "micro"
      frontend: "nano"
    conversations:
      backend: "micro"
      frontend: "nano"
    bureaublad:
      backend: "micro"
      frontend: "nano"

  # specify the subdomain for each component. this name will be combined with the base domain specified in the `domain` variable above
  hostname:
    keycloak: "id"
    element: "element"
    synapse: "matrix"
    grist: "grist"
    collabora: "collabora"
    nextcloud: "nextcloud"
    openproject: "openproject"
    livekit: "livekit"
    meet: "meet"
    conversations: "conversations"
    docs: "docs"
    bureaublad: "bureaublad"
    drive: "drive"
    # static nginx sidecar hostnames — gateway picks these up automatically
    conversations-static: "static-conversations"
    drive-static: "static-drive"
    meet-static: "static-meet"
    docs-static: "static-docs"
    # minio hostnames — gateway picks these up automatically
    drive-minio: "drive-minio"

  defaultLocale: "nl"

  # Global TLS configuration for all applications
  tls:
    enabled: true
    selfSigned: false
