---
### This file contains all the kubernetes cluster-wide settings, please edit it to match your environment.
cluster:
  networking:
    domain: cluster.local
    podSubnet:
      - "10.244.0.0/16"
    serviceSubnet:
      - "10.96.0.0/12"

  # routingMode selects the routing technology.
  # Allowed values: ingress, gateway-api, none.
  # For ingress mode, set cluster.ingress.type to nginx or haproxy-openshift, traefik
  routingMode: ingress

  ingress:                # ingress config (used when routingMode = ingress)
    type: nginx         # nginx or haproxy-openshift, traefik
    className: ~
    # Annotations applied to every Ingress resource.
    annotations: ~

  gateway:                # Gateway API config (used when routingMode = gateway-api)
    name: mijnbureau-gateway
    namespace: ~   # defaults to same namespace as the route
    className: ~   # gatewayClassName for the Gateway resource
    certManagerClusterIssuer: ~
    # allowedRoutesNamespacesFrom controls which namespaces may attach HTTPRoutes to the Gateway.
    # Defaults to "All" because MijnBureau supports per-app namespaces.
    # For shared/production clusters consider "Selector" with an appropriate namespace label.
    allowedRoutesNamespacesFrom: ~
    # Annotations applied to every HTTPRoute resource.
    annotations: ~
  # Runtime class name for sandbox technology such as gvisor or kata
  runtimeClassName: ""
