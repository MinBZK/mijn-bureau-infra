# PVC are presistent volume claims that are used to store data that needs to persist across pod restarts.
pvc:
  default:
    storageClass: ~
    size: "1Gi"
    accessModes:
      - ReadWriteOnce

  ollama:
    storageClass: ~
    size: 15Gi
    accessModes: []

  grist:
    grist:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []
    minio:
      storageClass: ~
      size: ~
      accessModes: []
    redis:
      storageClass: ~
      size: ~
      accessModes: []

  keycloak:
    keycloak:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []

  synapse:
    synapse:
      storageClass: ~
      size: ~
      accessModes: []
    redis:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []

  nextcloud:
    # Nextcloud config + custom apps + theme assets. Primary user data lives
    # in MinIO (object storage), so this PVC stays modest.
    nextcloud:
      storageClass: ~
      size: "8Gi"
      accessModes: []
    # Database holds metadata, file index, share state — grows with users not files.
    postgresql:
      storageClass: ~
      size: "10Gi"
      accessModes: []
    # MinIO is where actual user files land. Size for production scale; demo
    # environments can override smaller in helmfile/environments/demo/.
    minio:
      storageClass: ~
      size: "50Gi"
      accessModes: []
    redis:
      storageClass: ~
      size: ~
      accessModes: []

  openproject:
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []
    minio:
      storageClass: ~
      size: ~
      accessModes: []
    redis:
      storageClass: ~
      size: ~
      accessModes: []

  livekit:
    redis:
      storageClass: ~
      size: ~
      accessModes: []

  meet:
    redis:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []

  conversations:
    redis:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []

  docs:
    redis:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []
    minio:
      storageClass: ~
      size: ~
      accessModes: []

  drive:
    redis:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []
    minio:
      storageClass: ~
      size: ~
      accessModes: []

  clamav:
    storageClass: ~
    # ClamAV recommends 5 GiB minimum disk space for virus signature databases.
    # See: https://docs.clamav.net/#recommended-system-requirements
    size: "5Gi"
    accessModes: []

  bureaublad:
    redis:
      storageClass: ~
      size: ~
      accessModes: []

  messages:
    redis:
      storageClass: ~
      size: ~
      accessModes: []
    postgresql:
      storageClass: ~
      size: ~
      accessModes: []
    minio:
      storageClass: ~
      size: ~
      accessModes: []
    opensearch:
      storageClass: ~
      size: ~
      accessModes: []
