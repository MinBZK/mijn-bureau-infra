{{/*
  Points the AI configuration at the in-cluster ollama service when ollama
  is enabled and the environment did not set it. Only keys that are actually
  derived are emitted: emitting an empty map would null out the whole
  ai.llm subtree (user overrides) on merge.
*/}}
{{- $llm := dict }}
{{- if .Values.application.ollama.enabled }}
{{- if not .Values.ai.llm.model }}
{{- $_ := set $llm "model" .Values.application.ollama.model }}
{{- end }}
{{- if not .Values.ai.llm.endpoint.host }}
{{- $_ := set $llm "endpoint" (dict "host" "ollama" "port" 11434 "path" "v1" "isSsl" false "isInternal" true) }}
{{- end }}
{{- if not .Values.ai.llm.apiKey }}
{{- $_ := set $llm "apiKey" "" }}
{{- end }}
{{- end }}
{{- if $llm }}
ai:
  llm:
    {{- $llm | toYaml | nindent 4 }}
{{- end }}
