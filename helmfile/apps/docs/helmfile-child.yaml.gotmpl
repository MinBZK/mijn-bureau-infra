bases:
  - "../../bases/default.yaml.gotmpl"

repositories:
  - name: docs-repo
    url: "git+https://github.com/suitenumerique/docs@src/helm?ref=v3.2.1"


releases:
  - name: "docs"
    chart: "docs-repo/docs"
    namespace: {{ .Values.application.docs.namespace }}
    installed: {{ .Values.application.docs.enabled }}
