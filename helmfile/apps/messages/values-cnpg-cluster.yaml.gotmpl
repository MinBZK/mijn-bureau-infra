fullnameOverride: messages-cluster

type: postgresql

version:
  postgresql: "17"

mode: standalone

cluster:
  imageName: {{ printf "%s/%s:%s" .Values.container.cnpg_postgres.registry .Values.container.cnpg_postgres.repository .Values.container.cnpg_postgres.tag }}
  instances: 1

  enableSuperuserAccess: true
  superuserSecret: messages-cluster-superuser

  {{- with (coalesce .Values.container.cnpg_postgres.imagePullSecret .Values.container.default.imagePullSecret) }}
  imagePullSecrets:
    - name: {{ . | quote }}
  {{- end }}

  storage:
    size: {{ coalesce .Values.pvc.messages.postgresql.size .Values.pvc.default.size "8Gi" }}
    {{- with (coalesce .Values.pvc.messages.postgresql.storageClass .Values.pvc.default.storageClass) }}
    storageClass: {{ . }}
    {{- end }}

  monitoring:
    enabled: {{ .Values.metric.enabled | default false }}
    podMonitor:
      enabled: {{ .Values.metric.serviceMonitor.enabled | default false }}

  initdb:
    database: {{ .Values.database.messages.name }}
    owner: {{ .Values.database.messages.user }}
    secret:
      name: messages-cluster-app

backups:
  enabled: false
