bases:
  - "helmfile/bases/environment.yaml.gotmpl"

---

bases:
  - "helmfile/bases/default.yaml.gotmpl"

# Computed value layer: derives defaults (OIDC endpoints, AI endpoint,
# livekit keys) for values the environment left empty. Loaded as an extra
# environment values layer so the results merge into .Values; the files
# only emit a key when the corresponding value is not already set.
environments:
  {{ .Environment.Name }}:
    values:
      - "helmfile/bases/logic/authentication.yaml.gotmpl"
      - "helmfile/bases/logic/ai.yaml.gotmpl"
      - "helmfile/bases/logic/livekit.yaml.gotmpl"

---

helmfiles:
  - path: "helmfile/apps/common/helmfile-gateway.yaml.gotmpl"
    values: &appvalues
      - {{ toYaml .Values | nindent 8 }}
  - path: "helmfile/apps/keycloak/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/ollama/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/clamav/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/grist/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/meet/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/element/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/collabora/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/nextcloud/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/openproject/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/livekit/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/conversations/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/docs/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/drive/helmfile-child.yaml.gotmpl"
    values: *appvalues
  - path: "helmfile/apps/bureaublad/helmfile-child.yaml.gotmpl"
    values: *appvalues
