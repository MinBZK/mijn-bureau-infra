environments:
  default:
  demo:
    values:
      - "helmfile/environments/demo/*.yaml.gotmpl"
  production:
    values:
      - "helmfile/environments/production/*.yaml.gotmpl"

bases:
  - "helmfile/bases/default.yaml.gotmpl"

helmfiles:
  - path: "helmfile/apps/keycloak/helmfile-child.yaml.gotmpl"
    values: &values
      - "helmfile/environments/default/*.yaml*"
      - "helmfile/environments/{{ .Environment.Name }}/*.yaml.gotmpl"
  - path: "helmfile/apps/docs/helmfile-child.yaml.gotmpl"
    values: *values
  # - path: "helmfile/apps/element/helmfile-child.yaml"
  #   values: *values
  # - path: "helmfile/apps/ollama/helmfile-child.yaml"
  #   values: *values

